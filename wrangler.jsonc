{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "digiepro",
  "main": "src/worker.mjs",
  "compatibility_date": "2026-06-18",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": [
      "/api/*",
      "/bolehnihadmin",
      "/bolehdong",
      "/seed-store.json"
    ]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "digiepro-db",
      "database_id": "0c239bf3-1c8e-444e-b082-0979798e232d"
    }
  ]
}
