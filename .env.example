# Salin isi ini ke file bernama .env di HOME Hostinger, sejajar dengan public_html.
# Jangan commit atau upload .env asli ke GitHub/public_html.
APP_ENV=production
APP_URL=https://jagoprem.shop
APP_TIMEZONE=Asia/Jakarta

ADMIN_PASSWORD=GANTI_PASSWORD_ADMIN_YANG_KUAT

# Premzone hanya dibaca api.php di server. Nama OPENAI_* lama tetap didukung
# sebagai fallback, tetapi konfigurasi baru gunakan PREMZONE_* berikut.
PREMZONE_API_KEY=PASTE_PREMZONE_API_KEY_DI_SINI
PREMZONE_BASE_URL=https://api.premzone.co/v1
PREMZONE_MODEL=gpt-5.6-luna
OPENAI_MAX_OUTPUT_TOKENS=160
OPENAI_REQUEST_TIMEOUT_MS=25000

# Batas AI CS agar token hemat dan tidak disalahgunakan.
AI_CHAT_ENABLED=true
AI_CHAT_CONTEXT_MESSAGES=4
AI_CHAT_MAX_MESSAGE_CHARS=1200
AI_CHAT_RATE_LIMIT_PER_MINUTE=3
AI_CHAT_DAILY_LIMIT_PER_VISITOR=10
AI_CHAT_DAILY_LIMIT_PER_USER=24
AI_CHAT_DAILY_LIMIT_PER_IP=30
AI_CHAT_GLOBAL_DAILY_LIMIT=300
AI_CHAT_TYPING_DELAY_MIN_MS=700
AI_CHAT_TYPING_DELAY_MAX_MS=1700
AI_CHAT_ESCALATION_CONFIDENCE=0.70
AI_CHAT_MAX_IMAGE_MB=5
AI_CHAT_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
AI_CHAT_HUMAN_TAKEOVER_ENABLED=true

# Opsional, isi ketika bot WhatsApp sudah siap.
WA_BOT_WEBHOOK=
